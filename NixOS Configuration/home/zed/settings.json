{
  "disable_ai": true,
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "session": {
    "trust_all_worktrees": true
  },
  "terminal": {
    "cursor_shape": "bar"
  },
  "base_keymap": "VSCode",
  "tab_bar": {
    "show_tab_bar_buttons": false
  },
  "sticky_scroll": {
    "enabled": false
  },
  "cursor_blink": true,
  "autosave": {
    "after_delay": {
      "milliseconds": 1000
    }
  },
  "file_types": {
    "json": [
      "*.canvas",
      "*.excalidraw"
    ],
    "yaml": [
      "*.base"
    ]
  },
  "auto_indent_on_paste": true,
  "show_whitespaces": "none",
  "soft_wrap": "editor_width",
  "tab_size": 4,
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Catppuccin Mocha"
  },
  "auto_install_extensions": {
    "nix": true,
    "rust": true,
    "toml": true
  },
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "buffer_font_size": 13.0,
  "hour_format": "hour24",
  "theme": {
    "mode": "dark",
    "light": "Ayu Light",
    "dark": "Base16 Da One Gray"
  },
  "ui_font_family": "SF Pro Display",
  "ui_font_size": 16.0
}

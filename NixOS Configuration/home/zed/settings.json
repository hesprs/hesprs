{
  "auto_update": false,
  "agent_servers": {
    "opencode": {
      "type": "registry"
    }
  },
  "buffer_line_height": "comfortable",
  "middle_click_paste": false,
  "scroll_sensitivity": 2.5,
  "disable_ai": false,
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },
  "session": {
    "trust_all_worktrees": true
  },
  "terminal": {
    "cursor_shape": "bar"
  },
  "base_keymap": "VSCode",
  "tab_bar": {
    "show_tab_bar_buttons": false
  },
  "sticky_scroll": {
    "enabled": false
  },
  "cursor_blink": true,
  "autosave": {
    "after_delay": {
      "milliseconds": 1000
    }
  },
  "file_types": {
    "json": [
      "*.canvas",
      "*.excalidraw"
    ],
    "yaml": [
      "*.base"
    ]
  },
  "auto_indent_on_paste": true,
  "show_whitespaces": "none",
  "soft_wrap": "editor_width",
  "tab_size": 4,
  "icon_theme": {
    "mode": "dark",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Mocha"
  },
  "auto_install_extensions": {
    "nix": true,
    "rust": true,
    "toml": true,
    "oxc": true
  },
  "buffer_font_family": "JetBrainsMono Nerd Font",
  "buffer_font_size": 13,
  "theme": "Base16 Da One Gray",
  "ui_font_family": "SF Pro Display",
  "ui_font_size": 16.0,
  "languages": {
    "Nix": {
      "language_servers": [
        "nixd",
        "!nil",
        "..."
      ]
    },
    "JavaScript": {
      "language_servers": [
        "!eslint",
        "..."
      ]
    },
    "TypeScript": {
      "language_servers": [
        "!eslint",
        "..."
      ]
    }
  }
}
